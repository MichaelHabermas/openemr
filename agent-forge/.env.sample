# AgentForge Clinical Co-Pilot runtime configuration.
# For Docker Compose, copy this file to docker/development-easy/.env on the host/VM.
# Do not commit docker/development-easy/.env or any real secrets.

# Draft provider mode (canonical env resolution: DraftProviderConfig::fromEnvironment()
# in src/AgentForge/ResponseGeneration/DraftProviderConfig.php):
# - openai: use the real OpenAI structured-output provider.
# - anthropic: use the Anthropic Messages API draft provider.
# - fixture: use deterministic fixture drafting for local tests/evals.
# - disabled: fail closed before drafting.
#
# If AGENTFORGE_DRAFT_PROVIDER is unset, mode is inferred: an Anthropic API key
# selects anthropic; else an OpenAI key selects openai; else fixture.
AGENTFORGE_DRAFT_PROVIDER=openai

# Required when AGENTFORGE_DRAFT_PROVIDER=openai.
# DraftProviderConfig also accepts OPENAI_API_KEY (same semantics as below).
AGENTFORGE_OPENAI_API_KEY=
# Optional alias if your environment already uses this name.
OPENAI_API_KEY=

# Optional OpenAI model override.
AGENTFORGE_OPENAI_MODEL=gpt-5.4-mini

# Optional pricing overrides for log-only estimated cost.
# Defaults for gpt-4o-mini are built into AgentForge:
# input $0.15 / 1M tokens, output $0.60 / 1M tokens.
# Source: https://developers.openai.com/api/docs/models/gpt-4o-mini
# Override these only if you change models or pricing changes.
# gpt-4o-mini pricing
# AGENTFORGE_OPENAI_INPUT_COST_PER_1M=0.15
# AGENTFORGE_OPENAI_OUTPUT_COST_PER_1M=0.60
# gpt-5.4-mini pricing
AGENTFORGE_OPENAI_INPUT_COST_PER_1M=0.75
AGENTFORGE_OPENAI_OUTPUT_COST_PER_1M=4.50

# OpenAI request timeout controls for local/VM manual testing.
AGENTFORGE_OPENAI_TIMEOUT_SECONDS=15
AGENTFORGE_OPENAI_CONNECT_TIMEOUT_SECONDS=5

# --- Anthropic draft provider (when mode is anthropic or key infers it) ---
# Required when using Anthropic as the draft provider.
# DraftProviderConfig also accepts ANTHROPIC_API_KEY (same semantics as below).
AGENTFORGE_ANTHROPIC_API_KEY=
# Optional alias if your environment already uses this name.
ANTHROPIC_API_KEY=

# Optional model override (default in code: claude-haiku-4-5-20251001).
AGENTFORGE_ANTHROPIC_MODEL=claude-haiku-4-5

# Optional pricing overrides for log-only estimated cost.
# Built-in defaults apply for the default Haiku model; leave blank if unsure.
# Override when you change models or pricing changes (see Anthropic pricing docs).
AGENTFORGE_ANTHROPIC_INPUT_COST_PER_1M=1.00
AGENTFORGE_ANTHROPIC_OUTPUT_COST_PER_1M=5.00
AGENTFORGE_ANTHROPIC_CACHE_WRITE_COST_PER_1M=1.25
AGENTFORGE_ANTHROPIC_CACHE_READ_COST_PER_1M=0.10

# Anthropic request timeout controls.
AGENTFORGE_ANTHROPIC_TIMEOUT_SECONDS=15
AGENTFORGE_ANTHROPIC_CONNECT_TIMEOUT_SECONDS=5

# --- Clinical document extraction (queued worker + VLM/fixture provider) ---
# Resolution: src/AgentForge/Document/Extraction/ExtractionProviderConfig.php
# Used by agent-forge/scripts/process-document-jobs.php (docker compose service agentforge-worker).
#
# AGENTFORGE_VLM_PROVIDER: "fixture" (SHA256 -> sidecar JSON under manifest) or "openai" (real VLM).
# With fixture mode, ExtractionProviderConfig must resolve a readable manifest path; if both
# AGENTFORGE_EXTRACTION_FIXTURE_MANIFEST and AGENTFORGE_EXTRACTION_FIXTURES_DIR are unset/empty,
# the provider loads an empty manifest and every job fails with missing_file.
#
# development-easy: docker-compose.yml sets a default in-container manifest path for the worker
# when this variable is left unset in .env. Override only if you relocate fixtures.
# Host-only PHP (no Docker): set an absolute path to agent-forge/fixtures/clinical-document-golden/extraction/manifest.json
AGENTFORGE_VLM_PROVIDER=fixture
AGENTFORGE_VLM_MODEL=fixture
AGENTFORGE_VLM_TIMEOUT_SECONDS=60
AGENTFORGE_VLM_CONNECT_TIMEOUT_SECONDS=10
AGENTFORGE_VLM_MAX_PAGES=5
AGENTFORGE_EXTRACTION_FIXTURE_MANIFEST=
AGENTFORGE_EXTRACTION_FIXTURES_DIR=
# Same OpenAI keys as draft section when AGENTFORGE_VLM_PROVIDER=openai (read in ExtractionProviderConfig).
# AGENTFORGE_OPENAI_API_KEY and OPENAI_API_KEY are already defined above.

# --- Week 2 guideline/document evidence providers ---
# Optional reranker credential. If unset, deterministic/local reranking is used
# where supported by the eval path.
AGENTFORGE_COHERE_API_KEY=
# Reviewer/deployment marker for the embedding model expected by the Week 2 environment.
# PHP runtime selection does not currently read this value.
AGENTFORGE_EMBEDDING_MODEL=text-embedding-3-small
# Reviewer/deployment marker used to identify the clinical-document flow.
# PHP runtime behavior does not currently branch on this value.
AGENTFORGE_CLINICAL_DOCUMENT_ENABLED=1

# Document worker loop (process-document-jobs.php); development-easy passes these into agentforge-worker.
AGENTFORGE_WORKER_NAME=intake-extractor
AGENTFORGE_WORKER_IDLE_SLEEP_SECONDS=5
AGENTFORGE_WORKER_MAX_ITERATIONS=0
# Optional HMAC salt for patient_ref in worker logs (PatientRefHasher); empty uses code default.
AGENTFORGE_PATIENT_REF_SALT=

# Clinical document golden eval output directory (run-clinical-document-evals.php).
# Empty: writes under agent-forge/eval-results in the repo.
AGENTFORGE_CLINICAL_DOCUMENT_EVAL_RESULTS_DIR=

# --- Eval and reporting (all tiers share AGENTFORGE_EVAL_RESULTS_DIR unless overridden) ---
# Defaults to agent-forge/eval-results under the repo when unset.
AGENTFORGE_EVAL_RESULTS_DIR=
# Tier 1 (run-sql-evidence-evals.php): optional separate output dir; falls back to AGENTFORGE_EVAL_RESULTS_DIR.
AGENTFORGE_SQL_EVAL_RESULTS_DIR=
# Label stored in Tier 1 JSON (e.g. local, ci). Defaults to local.
AGENTFORGE_SQL_EVAL_ENVIRONMENT=local
# Tier 2 live eval wall-clock budget in milliseconds. Default in code: 30000.
AGENTFORGE_TIER2_DEADLINE_MS=30000
# Non-empty: skip writing LATEST-SUMMARY-TIER*.md after eval runs (EvalLatestSummaryWriter).
AGENTFORGE_SKIP_LATEST_SUMMARY=
# OpenEMR site directory for Tier 1 SQL evals when not using the standard container layout.
# Defaults to <repo>/sites/default when unset (see run-sql-evidence-evals.php).
OE_SITE_DIR=

# --- Tier 4 deployed HTTP smoke (run-deployed-smoke.php; usually CI secrets, not compose) ---
# Required for smoke: login user with chart access to demo patients.
# Replace these placeholders locally or in CI secrets; never commit real values.
AGENTFORGE_SMOKE_USER=
AGENTFORGE_SMOKE_PASSWORD=
# Base URL of the deployed OpenEMR instance.
AGENTFORGE_DEPLOYED_URL=https://openemr.titleredacted.cc/
# Demo patient IDs (secondary required for cross-patient reuse cases).
AGENTFORGE_SMOKE_PRIMARY_PID=900001
AGENTFORGE_SMOKE_SECONDARY_PID=900002
# Tier 4 deployed smoke (run-deployed-smoke.php) only — not for run-evals-vm.sh, which
# needs a real SSH target (user@host). Use "local" for host-readable log grep, or
# "docker-compose" to grep inside the OpenEMR container via compose exec on the VM host.
# Set AGENTFORGE_SMOKE_SKIP_AUDIT_LOG=1 only for dry-runs without audit proof.
AGENTFORGE_VM_SSH_HOST='docker-compose'
AGENTFORGE_VM_AUDIT_LOG_PATH='/var/log/apache2/error.log'
AGENTFORGE_SMOKE_SKIP_AUDIT_LOG=
AGENTFORGE_SMOKE_TIMEOUT_S=90
# Free-form tag recorded in the smoke result JSON (e.g. github-actions-manual).
AGENTFORGE_SMOKE_EXECUTOR=local

# Optional Xdebug settings for local/VM manual testing.
XDEBUG_ON=0
XDEBUG_PROFILER_ON=0
