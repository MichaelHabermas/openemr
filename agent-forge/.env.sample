# AgentForge Clinical Co-Pilot runtime configuration.
# For Docker Compose, copy this file to docker/development-easy/.env on the host/VM.
# Do not commit docker/development-easy/.env or any real secrets.

# Draft provider mode (canonical env resolution: DraftProviderConfig::fromEnvironment()
# in src/AgentForge/ResponseGeneration/DraftProviderConfig.php):
# - openai: use the real OpenAI structured-output provider.
# - anthropic: use the Anthropic Messages API draft provider.
# - fixture: use deterministic fixture drafting for local tests/evals.
# - disabled: fail closed before drafting.
#
# If AGENTFORGE_DRAFT_PROVIDER is unset, mode is inferred: an Anthropic API key
# selects anthropic; else an OpenAI key selects openai; else fixture.
AGENTFORGE_DRAFT_PROVIDER=google

# Required when AGENTFORGE_DRAFT_PROVIDER=openai.
# You may alternatively provide OPENAI_API_KEY if your environment already uses that name.
AGENTFORGE_OPENAI_API_KEY=

# Optional OpenAI model override.
# AGENTFORGE_OPENAI_MODEL=gpt-4o-mini
AGENTFORGE_OPENAI_MODEL=gemini-3-flash-preview

# Optional pricing overrides for log-only estimated cost.
# Defaults for gpt-4o-mini are built into AgentForge:
# input $0.15 / 1M tokens, output $0.60 / 1M tokens.
# Source: https://developers.openai.com/api/docs/models/gpt-4o-mini
# Override these only if you change models or pricing changes.
AGENTFORGE_OPENAI_INPUT_COST_PER_1M=0.15
AGENTFORGE_OPENAI_OUTPUT_COST_PER_1M=0.60

# OpenAI request timeout controls for local/VM manual testing.
AGENTFORGE_OPENAI_TIMEOUT_SECONDS=15
AGENTFORGE_OPENAI_CONNECT_TIMEOUT_SECONDS=5

# --- Anthropic draft provider (when mode is anthropic or key infers it) ---
# Required when using Anthropic as the draft provider.
# You may alternatively provide ANTHROPIC_API_KEY if your environment already uses that name.
AGENTFORGE_ANTHROPIC_API_KEY=

# Optional model override (default in code: claude-haiku-4-5-20251001).
AGENTFORGE_ANTHROPIC_MODEL=

# Optional pricing overrides for log-only estimated cost.
# Built-in defaults apply for the default Haiku model; leave blank if unsure.
# Override when you change models or pricing changes (see Anthropic pricing docs).
AGENTFORGE_ANTHROPIC_INPUT_COST_PER_1M=
AGENTFORGE_ANTHROPIC_OUTPUT_COST_PER_1M=
AGENTFORGE_ANTHROPIC_CACHE_WRITE_COST_PER_1M=
AGENTFORGE_ANTHROPIC_CACHE_READ_COST_PER_1M=

# Anthropic request timeout controls.
AGENTFORGE_ANTHROPIC_TIMEOUT_SECONDS=15
AGENTFORGE_ANTHROPIC_CONNECT_TIMEOUT_SECONDS=5

# Optional eval result output directory.
# Defaults to agent-forge/eval-results when unset.
AGENTFORGE_EVAL_RESULTS_DIR=

# Optional Xdebug settings for local/VM manual testing.
XDEBUG_ON=0
XDEBUG_PROFILER_ON=0
