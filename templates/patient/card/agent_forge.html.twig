{% extends "patient/card/card_base.html.twig" %}

{% block content %}
<form id="agent-forge-form" class="agent-forge-panel" data-endpoint="{{ endpoint|attr }}" data-patient-id="{{ patientId|attr }}" data-csrf-token="{{ csrfToken|attr }}">
    <div class="form-group mb-2">
        <label for="agent-forge-question" class="sr-only">{{ "Question"|xlt }}</label>
        <textarea id="agent-forge-question" class="form-control form-control-sm" rows="3" maxlength="1000" placeholder="{{ "Ask about this chart"|xla }}"></textarea>
    </div>
    <div class="d-flex align-items-center justify-content-between">
        <button type="submit" class="btn btn-primary btn-sm">{{ "Send"|xlt }}</button>
        <span id="agent-forge-status" class="small text-muted" aria-live="polite"></span>
    </div>
    <div id="agent-forge-last-question" class="small text-muted mt-2 d-none"></div>
    <div id="agent-forge-response" class="alert mt-2 mb-0 d-none" role="status"></div>
</form>
<div id="agent-forge-source-overlay" class="agent-forge-source-overlay d-none" role="dialog" aria-modal="true" aria-labelledby="agent-forge-source-title">
    <div class="agent-forge-source-dialog">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <strong id="agent-forge-source-title">{{ "Source document citation"|xlt }}</strong>
            <button type="button" class="close" aria-label="{{ "Close"|xla }}" data-agent-forge-close-source>
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
        <div id="agent-forge-source-meta" class="small text-muted mb-2"></div>
        <div class="agent-forge-source-page">
            <div id="agent-forge-source-image-wrap" class="agent-forge-source-image-wrap d-none">
                <img id="agent-forge-source-image" class="agent-forge-source-image" alt="{{ "Source document page preview"|xla }}">
                <div id="agent-forge-source-box" class="agent-forge-source-box"></div>
            </div>
            <div id="agent-forge-source-fallback" class="agent-forge-source-fallback"></div>
        </div>
        <a id="agent-forge-source-link" class="btn btn-link btn-sm p-0 mt-2 d-none" target="_blank" rel="noopener noreferrer">{{ "Open source document"|xlt }}</a>
        <div id="agent-forge-source-quote" class="small mt-2"></div>
    </div>
</div>

<style>
.agent-forge-source-overlay {
    align-items: center;
    background: rgba(0, 0, 0, 0.35);
    bottom: 0;
    display: flex;
    justify-content: center;
    left: 0;
    padding: 1rem;
    position: fixed;
    right: 0;
    top: 0;
    z-index: 1050;
}
.agent-forge-source-overlay.d-none {
    display: none;
}
.agent-forge-source-dialog {
    background: var(--white, #fff);
    border-radius: 0.25rem;
    box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.25);
    max-width: 32rem;
    padding: 1rem;
    width: 100%;
}
	.agent-forge-source-page {
	    background: #f8f9fa;
	    border: 1px solid #ced4da;
	    height: 24rem;
	    max-height: 48vh;
	    overflow: auto;
	    position: relative;
	    width: 100%;
	}
	.agent-forge-source-image-wrap.d-none {
	    display: none;
	}
	.agent-forge-source-image-wrap {
	    background: #fff;
	    line-height: 0;
	    margin: 0 auto;
	    max-width: 100%;
	    position: relative;
	    width: max-content;
	}
	.agent-forge-source-image {
	    display: block;
	    height: auto;
	    max-width: 100%;
	    width: auto;
	}
	.agent-forge-source-box {
	    border: 2px solid #c62828;
	    background: rgba(198, 40, 40, 0.12);
	    position: absolute;
	    z-index: 2;
	}
.agent-forge-source-box.d-none {
    display: none;
}
.agent-forge-source-fallback {
    align-items: center;
    bottom: 0;
    color: #495057;
    display: flex;
    font-size: 0.875rem;
    justify-content: center;
    left: 0;
    padding: 1rem;
    position: absolute;
    right: 0;
    text-align: center;
    top: 0;
}
.agent-forge-source-fallback.d-none {
    display: none;
}
</style>

<script>
(function () {
    const form = document.getElementById('agent-forge-form');
    if (!form) {
        return;
    }

    const question = document.getElementById('agent-forge-question');
    const status = document.getElementById('agent-forge-status');
    const lastQuestion = document.getElementById('agent-forge-last-question');
    const response = document.getElementById('agent-forge-response');
    const submit = form.querySelector('button[type="submit"]');
    const sourceOverlay = document.getElementById('agent-forge-source-overlay');
    const sourceMeta = document.getElementById('agent-forge-source-meta');
    const sourceImageWrap = document.getElementById('agent-forge-source-image-wrap');
    const sourceImage = document.getElementById('agent-forge-source-image');
    const sourceBox = document.getElementById('agent-forge-source-box');
    const sourceFallback = document.getElementById('agent-forge-source-fallback');
    const sourceLink = document.getElementById('agent-forge-source-link');
    const sourceQuote = document.getElementById('agent-forge-source-quote');
    let conversationId = null;

    function appendTextBlock(parent, message, className) {
        if (message === '') {
            return;
        }

        const block = document.createElement('div');
        block.textContent = message;
        block.style.whiteSpace = 'pre-wrap';
        if (className) {
            block.className = className;
        }
        parent.appendChild(block);
    }

    function appendList(parent, label, items) {
        if (!items || items.length === 0) {
            return;
        }

        const wrapper = document.createElement('div');
        wrapper.className = 'mt-2';

        const heading = document.createElement('strong');
        heading.textContent = label;
        wrapper.appendChild(heading);

        const list = document.createElement('ul');
        list.className = 'mb-0 pl-3';

        items.forEach(function (item) {
            const row = document.createElement('li');
            row.textContent = item;
            list.appendChild(row);
        });

        wrapper.appendChild(list);
        parent.appendChild(wrapper);
    }

    function appendLineWithDocumentCitation(parent, line, details) {
        const detail = matchingDocumentDetailForLine(line, details);
        const suffix = detail ? evidenceCitationSuffix(detail) : '';
        const index = suffix ? line.indexOf(suffix) : -1;

        if (detail && index >= 0) {
            parent.appendChild(document.createTextNode(line.slice(0, index)));
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'btn btn-link btn-sm p-0 align-baseline';
            button.textContent = suffix;
            button.addEventListener('click', function () {
                fetchSourceReview(detail);
            });
            parent.appendChild(button);
            parent.appendChild(document.createTextNode(line.slice(index + suffix.length)));
            return;
        }

        parent.textContent = line;
    }

    function appendSectionContent(parent, content, details) {
        String(content || '').split('\n').filter(Boolean).forEach(function (line) {
            const row = document.createElement('div');
            row.style.whiteSpace = 'pre-wrap';
            appendLineWithDocumentCitation(row, line, details);
            parent.appendChild(row);
        });
    }

    function appendSections(parent, payload) {
        const sections = payload.sections || [];
        if (sections.length === 0) {
            return false;
        }

        const details = payload.citation_details || [];
        sections.forEach(function (section) {
            if (!section || !section.title || !section.content) {
                return;
            }

            const wrapper = document.createElement('div');
            wrapper.className = 'mt-2';

            const heading = document.createElement('strong');
            heading.textContent = section.title;
            wrapper.appendChild(heading);

            appendSectionContent(wrapper, section.content, details);
            parent.appendChild(wrapper);
        });

        return true;
    }

    function citationLabel(detail) {
        return [
            detail.display_label || detail.source_type || '',
            detail.source_date || '',
            detail.source_id || ''
        ].filter(Boolean).join(' | ');
    }

    function evidenceCitationSuffix(detail) {
        const citation = detail.citation || {};
        if (!citation.doc_type || !citation.page_or_section || !citation.field_or_chunk_id) {
            return '';
        }

        return 'Citation: ' + citation.doc_type + ', ' + citation.page_or_section + ', ' + citation.field_or_chunk_id;
    }

    function matchingDocumentDetailForLine(line, details) {
        if (!details || details.length === 0) {
            return null;
        }

        for (const detail of details) {
            if (!canFetchSourceReview(detail)) {
                continue;
            }
            const suffix = evidenceCitationSuffix(detail);
            if (suffix && line.indexOf(suffix) !== -1) {
                return detail;
            }
        }

        return null;
    }

    function documentIdFromCitation(detail, citation) {
        const rawId = citation.document_id || detail.document_id || detail.source_id || '';
        const match = String(rawId).match(/\d+/);
        return match ? match[0] : '';
    }

    function reviewUrl(detail) {
        const citation = detail.citation || {};
        const params = new URLSearchParams();
        params.set('document_id', documentIdFromCitation(detail, citation));
        params.set('job_id', citation.job_id || detail.job_id || '');
        if (citation.fact_id || detail.fact_id) {
            params.set('fact_id', citation.fact_id || detail.fact_id);
        }
        return 'agent_document_source_review.php?' + params.toString();
    }

    function canFetchSourceReview(detail) {
        return detail
            && (detail.source_type === 'document' || detail.source_type === 'document_review');
    }

    function hasBoundingBox(box) {
        if (!box) {
            return false;
        }
        const numbers = [box.x, box.y, box.width, box.height];
        if (!numbers.every(function (value) { return typeof value === 'number' && Number.isFinite(value); })) {
            return false;
        }
        return box.x >= 0
            && box.y >= 0
            && box.width > 0
            && box.height > 0
            && box.x + box.width <= 1
            && box.y + box.height <= 1;
    }

    function normalizeReviewPayload(detail, payload) {
        const reviewed = payload && payload.review ? payload.review : (payload && typeof payload === 'object' ? payload : {});
        const citation = reviewed.citation || {
            source_type: reviewed.source_type || '',
            source_id: reviewed.source_id || '',
            page_or_section: reviewed.page_or_section || '',
            field_or_chunk_id: reviewed.field_or_chunk_id || '',
            quote_or_value: reviewed.quote_or_value || '',
            bounding_box: reviewed.bounding_box || null
        };
        return {
            display_label: reviewed.display_label || detail.display_label || '',
            source_type: reviewed.source_type || detail.source_type || citation.source_type || '',
            source_id: reviewed.source_id || detail.source_id || citation.source_id || '',
            citation: citation,
            value: reviewed.value || reviewed.quote_or_value || detail.value || '',
            document_url: reviewed.document_url || '',
            page_image_url: reviewed.page_image_url || ''
        };
    }

    function showSourceBox(box) {
        sourceBox.className = 'agent-forge-source-box';
        sourceBox.style.left = (box.x * 100) + '%';
        sourceBox.style.top = (box.y * 100) + '%';
        sourceBox.style.width = (box.width * 100) + '%';
        sourceBox.style.height = (box.height * 100) + '%';
        sourceBox.scrollIntoView({ block: 'center', inline: 'nearest' });
    }

    function showSourceOverlay(detail, payload) {
        const reviewed = normalizeReviewPayload(detail, payload);
        const citation = reviewed.citation || {};
        const box = citation.bounding_box || {};
        sourceMeta.textContent = [
            reviewed.display_label || '',
            reviewed.source_type || '',
            reviewed.source_id || '',
            citation.page_or_section || '',
            citation.field_or_chunk_id || ''
        ].filter(Boolean).join(' | ');
        sourceQuote.textContent = citation.quote_or_value || reviewed.value || '';
        if (reviewed.document_url) {
            sourceLink.href = reviewed.document_url;
            sourceLink.className = 'btn btn-link btn-sm p-0 mt-2';
        } else {
            sourceLink.removeAttribute('href');
            sourceLink.className = 'btn btn-link btn-sm p-0 mt-2 d-none';
        }

        if (reviewed.page_image_url) {
            sourceImageWrap.className = 'agent-forge-source-image-wrap';
            sourceFallback.className = 'agent-forge-source-fallback d-none';
            sourceFallback.textContent = '';
            sourceBox.className = 'agent-forge-source-box d-none';
            sourceBox.removeAttribute('style');
            sourceImage.onload = function () {
                if (hasBoundingBox(box)) {
                    showSourceBox(box);
                }
            };
            sourceImage.onerror = function () {
                sourceImage.removeAttribute('src');
                sourceImageWrap.className = 'agent-forge-source-image-wrap d-none';
                sourceBox.className = 'agent-forge-source-box d-none';
                sourceBox.removeAttribute('style');
                sourceFallback.className = 'agent-forge-source-fallback';
                sourceFallback.textContent = {{ "Source page preview could not be rendered. Open the source document to review the cited page."|xlj }};
            };
            sourceImage.src = reviewed.page_image_url;
        } else {
            sourceImage.removeAttribute('src');
            sourceImageWrap.className = 'agent-forge-source-image-wrap d-none';
            sourceBox.className = 'agent-forge-source-box d-none';
            sourceBox.removeAttribute('style');
            sourceFallback.className = 'agent-forge-source-fallback';
            sourceFallback.textContent = [
                citation.page_or_section || {{ "Unknown page"|xlj }},
                citation.quote_or_value || reviewed.value || {{ "No quoted source text was returned."|xlj }}
            ].filter(Boolean).join(' - ');
        }
        sourceOverlay.className = 'agent-forge-source-overlay';
    }

    function fetchSourceReview(detail) {
        sourceMeta.textContent = {{ "Loading source review..."|xlj }};
        sourceQuote.textContent = '';
        sourceImage.removeAttribute('src');
        sourceImageWrap.className = 'agent-forge-source-image-wrap d-none';
        sourceBox.className = 'agent-forge-source-box d-none';
        sourceBox.removeAttribute('style');
        sourceFallback.className = 'agent-forge-source-fallback d-none';
        sourceFallback.textContent = '';
        sourceOverlay.className = 'agent-forge-source-overlay';

        top.restoreSession();
        fetch(reviewUrl(detail), {
            method: 'GET',
            credentials: 'same-origin',
            headers: {
                'Accept': 'application/json'
            }
        }).then(function (result) {
            if (!result.ok) {
                throw new Error('source review failed');
            }
            return result.json();
        }).then(function (payload) {
            showSourceOverlay(detail, payload);
        }).catch(function () {
            showSourceOverlay(detail, detail);
        });
    }

    function appendSources(parent, payload) {
        const details = payload.citation_details || [];
        if (details.length === 0) {
            appendList(parent, {{ "Sources"|xlj }}, payload.citations || []);
            return;
        }

        const wrapper = document.createElement('div');
        wrapper.className = 'mt-2';

        const heading = document.createElement('strong');
        heading.textContent = {{ "Sources"|xlj }};
        wrapper.appendChild(heading);

        const list = document.createElement('ul');
        list.className = 'mb-0 pl-3';

        details.forEach(function (detail) {
            const row = document.createElement('li');
            if (canFetchSourceReview(detail)) {
                const button = document.createElement('button');
                button.type = 'button';
                button.className = 'btn btn-link btn-sm p-0 align-baseline';
                button.textContent = citationLabel(detail);
                button.addEventListener('click', function () {
                    fetchSourceReview(detail);
                });
                row.appendChild(button);
            } else {
                row.textContent = citationLabel(detail);
            }
            list.appendChild(row);
        });

        wrapper.appendChild(list);
        parent.appendChild(wrapper);
    }

    function appendMissingOrUnchecked(parent, payload) {
        const items = payload.missing_or_unchecked_sections || [];
        if (items.length === 0) {
            return;
        }

        const details = payload.citation_details || [];
        const wrapper = document.createElement('div');
        wrapper.className = 'mt-2';

        const heading = document.createElement('strong');
        heading.textContent = {{ "Missing or Not Found"|xlj }};
        wrapper.appendChild(heading);

        const list = document.createElement('ul');
        list.className = 'mb-0 pl-3';

        items.forEach(function (item) {
            const row = document.createElement('li');
            appendLineWithDocumentCitation(row, item, details);

            list.appendChild(row);
        });

        wrapper.appendChild(list);
        parent.appendChild(wrapper);
    }

    function showMessage(message, level, payload) {
        response.textContent = '';
        response.style.whiteSpace = 'pre-wrap';
        response.className = 'alert mt-2 mb-0 alert-' + level;

        if (!payload) {
            appendTextBlock(response, message, '');
            return;
        }

        const renderedSections = payload.status === 'ok' && appendSections(response, payload);
        if (!renderedSections) {
            appendTextBlock(response, message, '');
        }

        if (!renderedSections) {
            appendMissingOrUnchecked(response, payload);
        }
        appendList(response, {{ "Warnings"|xlj }}, payload.refusals_or_warnings || []);

        if (payload.status === 'ok' && payload.citations && payload.citations.length > 0) {
            appendSources(response, payload);
            return;
        }

        if (
            payload.status === 'ok'
            && (!payload.citations || payload.citations.length === 0)
            && (!payload.missing_or_unchecked_sections || payload.missing_or_unchecked_sections.length === 0)
            && (!payload.refusals_or_warnings || payload.refusals_or_warnings.length === 0)
        ) {
            appendTextBlock(response, {{ "No chart sources were returned."|xlj }}, 'mt-2 font-italic');
        }
    }

    form.addEventListener('submit', function (event) {
        event.preventDefault();
        const value = question.value.trim();
        if (value === '') {
            showMessage({{ "Enter a question before sending."|xlj }}, 'warning', null);
            return;
        }

        top.restoreSession();
        status.textContent = {{ "Sending..."|xlj }};
        response.className = 'alert mt-2 mb-0 d-none';
        submit.disabled = true;

        const body = new FormData();
        body.append('csrf_token_form', form.dataset.csrfToken);
        body.append('patient_id', form.dataset.patientId);
        body.append('question', value);
        if (conversationId) {
            body.append('conversation_id', conversationId);
        }

        fetch(form.dataset.endpoint, {
            method: 'POST',
            credentials: 'same-origin',
            body: body
        }).then(function (result) {
            return result.json();
        }).then(function (payload) {
            question.value = '';
            lastQuestion.textContent = {{ "Question"|xlj }} + ': ' + value;
            lastQuestion.className = 'small text-muted mt-2';
            if (payload.conversation_id) {
                conversationId = payload.conversation_id;
            }
            if (payload.status === 'ok') {
                showMessage(payload.answer || '', 'info', payload);
            } else {
                payload.refusals_or_warnings = payload.refusals_or_warnings || [{{ "The request was refused."|xlj }}];
                showMessage('', 'warning', payload);
            }
        }).catch(function () {
            showMessage({{ "The request failed. Please try again."|xlj }}, 'danger', null);
        }).finally(function () {
            status.textContent = '';
            submit.disabled = false;
        });
    });

    sourceOverlay.addEventListener('click', function (event) {
        if (event.target === sourceOverlay || event.target.closest('[data-agent-forge-close-source]')) {
            sourceOverlay.className = 'agent-forge-source-overlay d-none';
        }
    });
}());
</script>
{% endblock %}
